{
  "info": {
    "name": "EduCloud Lite API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Student One\",\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Get Courses",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/courses"
      }
    },
    {
      "name": "Create Course",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/courses",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"AWS Cloud Basics\",\n  \"description\": \"Intro course\"\n}"
        }
      }
    },
    {
      "name": "Enroll Course",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/courses/1/enroll"
      }
    },
    {
      "name": "Upload Course Thumbnail",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/upload/course-thumbnail"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    }
  ]
}
