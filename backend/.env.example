APP_NAME=EduCloud Lite API
APP_ENV=development
API_PREFIX=/api
DATABASE_URL=postgresql://username:password@localhost:5432/educloud_lite
# For Supabase on an IPv4 network, copy the Session Pooler URI from Connect
# and add sslmode=require if the copied URI does not already include it:
# DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET_KEY=change-this-development-secret
JWT_ALGORITHM=HS256
ENABLE_DEV_AUTH=false
DEV_INSTRUCTOR_USER_ID=900001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=educloud-lite-demo-bucket
AWS_S3_PUBLIC_BASE_URL=
# Use local for localhost testing. Change to s3 after configuring AWS credentials and bucket access.
UPLOAD_STORAGE=local
LOCAL_UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://127.0.0.1:8001
