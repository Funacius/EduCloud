APP_NAME=EduCloud Lite API
APP_ENV=development
API_PREFIX=/api
# Create your own Supabase project, copy its Session Pooler URI from Connect,
# change postgresql:// to postgresql+psycopg2://, URL-encode the password,
# and keep sslmode=require. Never commit the completed connection string.
DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@POOLER_HOST:5432/postgres?sslmode=require
JWT_SECRET_KEY=GENERATE_YOUR_OWN_LONG_RANDOM_VALUE
JWT_ALGORITHM=HS256
# Create your own Cognito User Pool and public app client without a client secret.
COGNITO_REGION=YOUR_AWS_REGION
COGNITO_USER_POOL_ID=YOUR_COGNITO_USER_POOL_ID
COGNITO_CLIENT_ID=YOUR_COGNITO_APP_CLIENT_ID
# Keep true only while local seeded accounts are being migrated to Cognito. Set false in production.
ALLOW_LEGACY_AUTH=true
ENABLE_DEV_AUTH=false
DEV_INSTRUCTOR_USER_ID=900001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=YOUR_S3_BUCKET_NAME
AWS_S3_PUBLIC_BASE_URL=
# Optional read-only CloudWatch and Cost Explorer metrics for the Admin Health page.
AWS_MONITORING_ENABLED=false
# Use local for localhost testing. Change to s3 after configuring AWS credentials and bucket access.
UPLOAD_STORAGE=local
LOCAL_UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://127.0.0.1:8001
